generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FortuneStick {
  id        Int      @id
  level     String
  title     String
  poem      String
  meaning   String
  advice    String
  story     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fortune_sticks")
}
